      python - <<'PY'
import requests, json, re, html
from bs4 import BeautifulSoup
from pathlib import Path
from email.utils import parsedate_to_datetime

outdir = Path('/Users/lini03/baidu/agent-eval-arena/results/hermes/cat2/task-2d')
outdir.mkdir(parents=True, exist_ok=True)
headers={'User-Agent':'Mozilla/5.0'}

rss = requests.get('https://openai.com/blog/rss.xml', headers=headers, timeout=30).text
soup = BeautifulSoup(rss, 'xml')
items = soup.find_all('item')[:5]
posts=[]
for item in items:
    title = item.title.get_text(strip=True)
    link = item.link.get_text(strip=True)
    pub = item.pubDate.get_text(strip=True)
    dt = parsedate_to_datetime(pub)
    date = dt.strftime('%Y-%m-%d')
    desc = item.description.get_text(' ', strip=True) if item.description else ''
    posts.append({'title': title, 'date': date, 'link': link, 'description': desc})

(outdir/'blog-posts.json').write_text(json.dumps([
    {'title': p['title'], 'date': p['date']} for p in posts
], indent=2), encoding='utf-8')

latest = posts[0]
mirror_url = 'https://r.jina.ai/http://' + latest['link']
text = requests.get(mirror_url, headers=headers, timeout=60).text
(outdir/'latest-post-raw.md').write_text(text, encoding='utf-8')

# Clean up markdown-ish text to readable plain text.
content = text
content = re.sub(r'^Title:.*\n', '', content, flags=re.M)
content = re.sub(r'^URL Source:.*\n', '', content, flags=re.M)
content = re.sub(r'^Markdown Content:\n', '', content, flags=re.M)
content = content.replace('\r', '')
# Remove markdown links but keep anchor text
content = re.sub(r'\[([^\]]+)\]\([^\)]+\)', r'\1', content)
# Remove navigation noise before the dated heading if possible
m = re.search(r'\n(?:[A-Z][a-z]+ \d{1,2}, \d{4})\n.*?\n#\s+(.+?)\n', content, flags=re.S)
if m:
    start = m.start()
    content = content[start:].strip()
# Remove some common site chrome lines
lines=[]
for line in content.splitlines():
    s=line.strip()
    if s in {'Skip to main content','Loading…','Share','OpenAI','Research','Products','Business','Developers','Company','Login','Log in','Try ChatGPT(opens in a new window)','Try ChatGPT','Table of contents'}:
        continue
    if re.fullmatch(r'\*\s+.+', s):
        # drop table of contents bullets and nav bullets
        continue
    if s.startswith('[]('):
        continue
    lines.append(line)
content='\n'.join(lines)
content = re.sub(r'\n{3,}', '\n\n', content).strip() + '\n'
(outdir/'latest-post.txt').write_text(content, encoding='utf-8')

# 3-sentence summary from lead paragraphs.
paras = [p.strip() for p in re.split(r'\n\s*\n', content) if p.strip()]
# find body paragraphs after title/date section
body=[]
for p in paras:
    if len(p.split()) > 18 and not p.startswith('#') and not re.match(r'^[A-Z][a-z]+ \d{1,2}, \d{4}$', p):
        body.append(p)
summary_sentences=[]
for p in body[:4]:
    # split into sentences naively
    sents = re.split(r'(?<=[.!?])\s+', p)
    for s in sents:
        s=s.strip()
        if len(s.split()) > 6:
            summary_sentences.append(s)
        if len(summary_sentences) >= 3:
            break
    if len(summary_sentences) >= 3:
        break
summary = ' '.join(summary_sentences[:3]).strip() + '\n'
(outdir/'summary.txt').write_text(summary, encoding='utf-8')

# Generate local HTML overview and post pages for browser automation/screenshots.
overview_items='\n'.join(
    f"<li><a href='latest-post.html'>{html.escape(posts[0]['title'])}</a> <span class='date'>{posts[0]['date']}</span></li>" if i==0 else
    f"<li><a href='{html.escape(p['link'])}'>{html.escape(p['title'])}</a> <span class='date'>{p['date']}</span></li>"
    for i,p in enumerate(posts)
)
overview_html=f'''<!doctype html>
<html><head><meta charset="utf-8"><title>OpenAI Blog Overview</title>
<style>
body{{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Arial,sans-serif;max-width:1000px;margin:40px auto;padding:0 24px;line-height:1.5;color:#111}}
h1{{font-size:40px;margin-bottom:12px}} .note{{color:#555;margin-bottom:24px}}
ul{{padding-left:22px}} li{{margin:14px 0;font-size:22px}} .date{{color:#666;margin-left:12px;font-size:18px}}
a{{color:#0a58ca;text-decoration:none}}
pre{{white-space:pre-wrap}}
</style></head><body>
<h1>OpenAI Blog - 5 Most Recent Posts</h1>
<p class="note">Source data extracted from OpenAI's RSS feed because the live blog page returned bot protection in this environment.</p>
<ul>{overview_items}</ul>
</body></html>'''
(outdir/'overview.html').write_text(overview_html, encoding='utf-8')

escaped = html.escape(content)
post_html=f'''<!doctype html>
<html><head><meta charset="utf-8"><title>{html.escape(latest['title'])}</title>
<style>
body{{font-family:Georgia,serif;max-width:900px;margin:40px auto;padding:0 24px;line-height:1.6;color:#111}}
h1{{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Arial,sans-serif;font-size:42px;line-height:1.2;margin-bottom:8px}}
.meta{{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Arial,sans-serif;color:#666;margin-bottom:28px}}
.summary{{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Arial,sans-serif;background:#f5f5f5;padding:14px 18px;border-radius:10px;margin-bottom:26px}}
pre{{white-space:pre-wrap;word-wrap:break-word;font-size:19px}}
</style></head><body>
<h1>{html.escape(latest['title'])}</h1>
<div class="meta">{latest['date']} • Original URL: <a href="{html.escape(latest['link'])}">{html.escape(latest['link'])}</a></div>
<div class="summary"><strong>3-sentence summary:</strong> {html.escape(summary.strip())}</div>
<pre>{escaped}</pre>
</body></html>'''
(outdir/'latest-post.html').write_text(post_html, encoding='utf-8')

print(json.dumps({'posts': posts, 'latest_link': latest['link'], 'mirror_url': mirror_url, 'outdir': str(outdir)}, indent=2))
